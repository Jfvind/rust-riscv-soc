*.log
*.jou
*.str
*.pb
*.dcp
*.bit
*.bin
.Xil/

# ========================
# 2. Rust (Software)
# ========================
# Standard Rust build folder
target/
**/*.rs.bk

# ========================
# 3. Chisel / Scala (Wildcat)
# ========================
# sbt specific
dist/
target/
lib_managed/
src_managed/
project/boot/
project/plugins/project/
.history
.cache
.lib/

# Chisel generated files
test_run_dir/
*.fir
*.anno.json
*.vcd
*.sv

# IMPORTANT: We usually WANT to keep the generated Verilog 
# if we are treating Wildcat as a submodule, but if you 
# generate it fresh every time, you can ignore it.
# Uncomment the line below to ignore generated Verilog:
# *.v

